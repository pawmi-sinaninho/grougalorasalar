{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/grougalorasalar/solver-fixture-catalog.schema.json",
  "title": "VerifiedRulesFixtureCatalog",
  "type": "object",
  "required": ["schemaVersion", "catalogId", "fixtureCount", "fixtures", "resourceTransitions", "indecision", "movement"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "catalogId": {"const": "verified-rules-2026-06-30"},
    "fixtureCount": {"type": "integer", "minimum": 1},
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fixtureId", "title", "focusRuleIds", "given"],
        "properties": {
          "fixtureId": {"type": "string", "pattern": "^F-[0-9]{3}$"},
          "title": {"type": "string"},
          "focusRuleIds": {"type": "array", "items": {"type": "string"}},
          "given": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "resourceTransitions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["start", "casts", "matchingWhiteHits", "next"],
        "properties": {
          "start": {"type": "integer", "minimum": 0, "maximum": 4},
          "casts": {"type": "integer", "minimum": 0, "maximum": 4},
          "matchingWhiteHits": {"type": "integer", "minimum": 0},
          "next": {"type": "integer", "minimum": 0, "maximum": 4}
        },
        "additionalProperties": false
      }
    },
    "indecision": {
      "type": "object",
      "required": ["source", "legalOffsets", "illegalDiagonalOffsets"]
    },
    "movement": {
      "type": "object",
      "required": ["refletExactRange", "refletAlignments", "rejetCardinalFinalDistanceFromPillar", "rejetDiagonalFinalDistanceFromPillar", "rejetAdjacentCardinalDisplacement", "attraitMaximumDistance", "attraitStopsBeforePillar"]
    }
  },
  "additionalProperties": false
}
