{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/grougalorasalar/solver-fixture-catalog.schema.json",
  "title": "SolverFixtureCatalog",
  "type": "object",
  "required": [
    "schemaVersion",
    "catalogId",
    "fixtureCount",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.5.0"
    },
    "catalogId": {
      "type": "string"
    },
    "fixtureCount": {
      "type": "integer",
      "minimum": 1
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixture"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "cell": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "nullableCell": {
      "anyOf": [
        {
          "$ref": "#/$defs/cell"
        },
        {
          "type": "null"
        }
      ]
    },
    "offset": {
      "type": "object",
      "required": [
        "dx",
        "dy"
      ],
      "properties": {
        "dx": {
          "type": "integer"
        },
        "dy": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "spellState": {
      "type": "object",
      "required": [
        "availability",
        "value",
        "confirmed"
      ],
      "properties": {
        "availability": {
          "enum": [
            "available",
            "unavailable",
            "unknown"
          ]
        },
        "value": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "confirmed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "conditionalAction": {
      "type": "object",
      "required": [
        "signature",
        "ruleIds"
      ],
      "properties": {
        "signature": {
          "type": "string"
        },
        "ruleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^R-[0-9]{3}$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "terminalOutcome": {
      "type": "object",
      "required": [
        "sequence",
        "classification",
        "finalCell",
        "raceOutcome"
      ],
      "properties": {
        "sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "classification": {
          "enum": [
            "definite",
            "conditional",
            "invalid"
          ]
        },
        "finalCell": {
          "$ref": "#/$defs/nullableCell"
        },
        "raceOutcome": {
          "enum": [
            "crocoburio_advance",
            "dragon_advance",
            "neutral",
            "unknown"
          ]
        },
        "ruleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^R-[0-9]{3}$"
          }
        }
      },
      "additionalProperties": false
    },
    "fixture": {
      "type": "object",
      "required": [
        "fixtureId",
        "title",
        "fixtureClass",
        "focusRuleIds",
        "given",
        "expected"
      ],
      "properties": {
        "fixtureId": {
          "type": "string",
          "pattern": "^F-[0-9]{3}$"
        },
        "title": {
          "type": "string"
        },
        "fixtureClass": {
          "enum": [
            "synthetic_contract",
            "manual_reference_gate"
          ]
        },
        "focusRuleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^R-[0-9]{3}$"
          },
          "uniqueItems": true
        },
        "given": {
          "type": "object",
          "required": [
            "summary",
            "profileMode",
            "profileId",
            "arena",
            "player",
            "pillars",
            "glyphs",
            "resources",
            "flags"
          ],
          "properties": {
            "summary": {
              "type": "string"
            },
            "profileMode": {
              "enum": [
                "explicit_test_profile",
                "real_authority_profile"
              ]
            },
            "arena": {
              "type": "object",
              "required": [
                "walkable",
                "boundaryUnverified",
                "occludedUnknown",
                "permanentBlocked"
              ],
              "properties": {
                "walkable": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                },
                "boundaryUnverified": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                },
                "occludedUnknown": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                },
                "permanentBlocked": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false
            },
            "player": {
              "type": "object",
              "required": [
                "current",
                "previous"
              ],
              "properties": {
                "current": {
                  "$ref": "#/$defs/cell"
                },
                "previous": {
                  "$ref": "#/$defs/nullableCell"
                }
              },
              "additionalProperties": false
            },
            "pillars": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "cell",
                  "spellType"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "cell": {
                    "$ref": "#/$defs/cell"
                  },
                  "spellType": {
                    "enum": [
                      "indecision",
                      "reflection",
                      "repulsion",
                      "attraction"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "glyphs": {
              "type": "object",
              "required": [
                "blackOffsets",
                "whiteOffsets",
                "physicalBlackCells",
                "physicalWhiteCells"
              ],
              "properties": {
                "blackOffsets": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/offset"
                  },
                  "uniqueItems": true
                },
                "whiteOffsets": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/offset"
                  },
                  "uniqueItems": true
                },
                "physicalBlackCells": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                },
                "physicalWhiteCells": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false
            },
            "resources": {
              "type": "object",
              "required": [
                "actionBudget",
                "spells"
              ],
              "properties": {
                "actionBudget": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "spells": {
                  "type": "object",
                  "required": [
                    "indecision",
                    "reflection",
                    "repulsion",
                    "attraction"
                  ],
                  "properties": {
                    "indecision": {
                      "$ref": "#/$defs/spellState"
                    },
                    "reflection": {
                      "$ref": "#/$defs/spellState"
                    },
                    "repulsion": {
                      "$ref": "#/$defs/spellState"
                    },
                    "attraction": {
                      "$ref": "#/$defs/spellState"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "flags": {
              "type": "object",
              "required": [
                "anchorConfirmed",
                "criticalFieldsConfirmed",
                "multiplayerDetected"
              ],
              "properties": {
                "anchorConfirmed": {
                  "type": "boolean"
                },
                "criticalFieldsConfirmed": {
                  "type": "boolean"
                },
                "multiplayerDetected": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "profileOverrides": {
              "type": "object"
            },
            "profileId": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "expected": {
          "type": "object",
          "required": [
            "status",
            "statusReasonCodes",
            "definiteRootActions",
            "conditionalRootActions",
            "terminalOutcomes",
            "orderedRecommendedSequences"
          ],
          "properties": {
            "status": {
              "enum": [
                "solved",
                "confirmation_required",
                "blocked_unverified_rule",
                "no_safe_solution",
                "invalid_state"
              ]
            },
            "statusReasonCodes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "definiteRootActions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "conditionalRootActions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/conditionalAction"
              }
            },
            "terminalOutcomes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/terminalOutcome"
              }
            },
            "orderedRecommendedSequences": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
