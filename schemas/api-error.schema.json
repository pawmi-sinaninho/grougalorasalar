{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/grougalorasalar/api-error.schema.json",
  "title": "ApiError",
  "type": "object",
  "required": [
    "schemaVersion",
    "error"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.6.0"
    },
    "error": {
      "type": "object",
      "required": [
        "code",
        "httpStatus",
        "messageKey",
        "requestId",
        "retryable",
        "fieldErrors",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^API-[A-Z]+-[A-Z0-9-]+$"
        },
        "httpStatus": {
          "type": "integer",
          "minimum": 400,
          "maximum": 599
        },
        "messageKey": {
          "type": "string",
          "minLength": 1
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "fieldErrors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "code",
              "messageKey"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "messageKey": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "details": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
