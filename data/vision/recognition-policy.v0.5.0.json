{
  "schemaVersion": "0.5.0",
  "policyId": "recognition-policy-v0.5.0",
  "status": "specification_target_not_measured",
  "supportedInput": {
    "mimeTypes": [
      "image/png",
      "image/jpeg",
      "image/webp"
    ],
    "minimumDimensions": {
      "width": 1280,
      "height": 720
    },
    "maximumMegapixels": 33.2,
    "requiredContent": [
      "main_arena",
      "controlled_player",
      "central_glyph_pattern"
    ],
    "optionalButNeededForFullOutput": [
      "spell_resource_area",
      "progress_tracks"
    ]
  },
  "arenaPresence": {
    "primary": "stable-map-landmark-and-floor-line registration hypothesis",
    "crossChecks": [
      "two isometric line families",
      "minimum landmark coverage in three board regions",
      "candidate arena mask overlap"
    ],
    "acceptThreshold": 0.97,
    "reviewThreshold": 0.8,
    "rejectBelow": 0.8,
    "falseAcceptPolicy": "zero tolerated on locked negative corpus"
  },
  "registration": {
    "model": "logical-grid affine basis: pixel = origin + x*basisX + y*basisY",
    "minimumInliers": 6,
    "minimumSpatialRegions": 3,
    "candidateLimit": 5,
    "accepted": {
      "medianResidualCellsMax": 0.06,
      "p95ResidualCellsMax": 0.1,
      "confidenceMin": 0.97
    },
    "review": {
      "medianResidualCellsMax": 0.1,
      "p95ResidualCellsMax": 0.16,
      "confidenceMin": 0.8
    },
    "rejectWhen": [
      "p95 residual exceeds 0.16 cells",
      "fewer than 6 inliers",
      "basis orientation conflicts with arena model",
      "best and second-best hypotheses are not separated by 0.08 confidence",
      "arena crop omits a critical board region"
    ]
  },
  "fieldThresholds": {
    "player.currentCell": {
      "autoConfirm": 0.95,
      "reviewMin": 0.7,
      "criticality": "solver_blocking"
    },
    "pillarSet": {
      "autoConfirm": 0.97,
      "reviewMin": 0.75,
      "criticality": "solver_blocking"
    },
    "pillars.*.cell": {
      "autoConfirm": 0.95,
      "reviewMin": 0.7,
      "criticality": "solver_blocking"
    },
    "pillars.*.spellType": {
      "autoConfirm": 0.93,
      "reviewMin": 0.7,
      "criticality": "solver_blocking"
    },
    "glyphPattern.blackOffsets": {
      "autoConfirm": 0.97,
      "reviewMin": 0.8,
      "criticality": "solver_blocking"
    },
    "glyphPattern.whiteOffsets": {
      "autoConfirm": 0.95,
      "reviewMin": 0.75,
      "criticality": "solver_blocking"
    },
    "glyphPattern.anchorCell": {
      "autoConfirm": 0.99,
      "reviewMin": 0.9,
      "criticality": "solver_blocking"
    },
    "spellState.actionBudget": {
      "autoConfirm": 0.98,
      "reviewMin": 0.8,
      "criticality": "solver_blocking"
    },
    "spellState.spells.*": {
      "autoConfirm": 0.95,
      "reviewMin": 0.75,
      "criticality": "solver_blocking"
    },
    "turnContext.multiplayerDetected": {
      "autoConfirm": 0.98,
      "reviewMin": 0.85,
      "criticality": "solver_blocking"
    },
    "progress.*.index": {
      "autoConfirm": 0.92,
      "reviewMin": 0.7,
      "criticality": "terminal_only"
    }
  },
  "autoConfirmation": {
    "enabledByDefault": false,
    "enableOnlyWhen": [
      "modelCalibrationStatus is validated",
      "locked-test acceptance gates pass",
      "field has an independent cross-check",
      "no open conflict",
      "input is within supported distribution"
    ],
    "manualConfirmationDoesNotChangeConfidence": true
  },
  "confidenceFormula": {
    "base": "weighted geometric mean of primary, registration, snapMargin, visibility and crossCheck component scores",
    "weights": {
      "primary": 0.35,
      "registration": 0.2,
      "snapMargin": 0.15,
      "visibility": 0.15,
      "crossCheck": 0.15
    },
    "hardCaps": {
      "no_independent_crosscheck": 0.79,
      "unresolved_method_conflict": 0.39,
      "out_of_distribution": 0.49,
      "snap_margin_below_0_15_cell": 0.69,
      "partial_occlusion_without_temporal_support": 0.74
    }
  },
  "solverGate": {
    "readyOnlyWhen": [
      "arena presence confirmed",
      "registration confirmed",
      "solo state confirmed",
      "player cell confirmed",
      "pillar set completeness and every pillar cell/type confirmed",
      "black and white glyph sets confirmed",
      "projection anchor confirmed",
      "action budget confirmed or supplied by authoritative RulesProfile",
      "all spell states required by the chosen resource mode confirmed",
      "no blocker conflict"
    ],
    "progressException": "unknown progress does not block per-turn race direction, but blocks immediate terminal win/loss claims",
    "unvalidatedModelRule": "while modelCalibrationStatus is unvalidated, all automatically extracted solver-blocking fields require user confirmation regardless of numeric confidence"
  }
}
